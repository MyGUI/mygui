# Find MYGUI - CMake package configuration file
#
# Targets provided:
#   MyGUI::MyGUI           - MyGUI engine library
#   MyGUI::OgrePlatform    - Ogre render platform     (when available)
#   MyGUI::OpenGLPlatform  - OpenGL render platform   (when available)
#   MyGUI::OpenGL3Platform - OpenGL 3.x render platform (when available)
#   MyGUI::OpenGLESPlatform- OpenGL ES render platform (when available)
#   MyGUI::DirectXPlatform - DirectX render platform   (when available)
#   MyGUI::DirectX11Platform - DirectX 11 render platform (when available)
#   MyGUI::DummyPlatform   - Dummy render platform     (when available)
#
# Variables defined (for compatibility):
#  MYGUI_INCLUDE_DIRS
#  MYGUI_LIBRARIES
#  MYGUI_LIBRARY_DIRS

@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(pugixml)

# Dependencies needed by the built platform target
@MYGUI_CONFIG_FIND_DEPS@

include("${CMAKE_CURRENT_LIST_DIR}/MyGUITargets.cmake")

set(MYGUI_LIBRARY_DIRS "@PACKAGE_CMAKE_INSTALL_LIBDIR@")
set(MYGUI_INCLUDE_DIRS "@PACKAGE_CMAKE_INSTALL_INCLUDEDIR@/MYGUI")
set(MYGUI_LIBRARIES "MyGUIEngine")

check_required_components(MyGUI)
